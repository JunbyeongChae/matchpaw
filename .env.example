DATABASE_URL=          # Neon PostgreSQL 연결 문자열 (Vercel 통합 시 자동 주입)
JWT_SECRET=            # 랜덤 32자 이상 문자열
ANIMAL_API_KEY=        # 국가동물보호정보시스템 API 키
GEMINI_API_KEY=        # Google Gemini API 키 (aistudio.google.com/app/apikey)
RESEND_API_KEY=        # Resend 이메일 발송 API 키 (resend.com)
APP_URL=               # 배포 URL (로컬: http://localhost:3000, 프로덕션: https://your-domain.vercel.app)
